{
  "openapi": "3.0.3",
  "info": {
    "title": "Gallery App API",
    "description": "API para gerenciamento da aplicação Gallery App.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:4000",
      "description": "Servidor local"
    }
  ],
  "tags": [
    {
      "name": "Auth",
      "description": "Operações de autenticação"
    },
    {
      "name": "User",
      "description": "Operações relacionadas aos usuários"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/auth/register": {
      "$ref": "./paths/auth/register.json"
    },
    "/auth/login": {
      "$ref": "./paths/auth/sign-in.json"
    },
    "/auth/confirm-email": {
      "$ref": "./paths/auth/confirm-email.json"
    },
    "/auth/send-forgot-password": {
      "$ref": "./paths/auth/send-forgot-password.json"
    },
    "/auth/reset-password/validate": {
      "$ref": "./paths/auth/reset-password-validate.json"
    },
    "/auth/reset-password": {
      "$ref": "./paths/auth/reset-password.json"
    },

    "/user/me": {
      "$ref": "./paths/user/me.json"
    },
    "/user/me/avatar": {
      "$ref": "./paths/user/me_avatar.json"
    }
  },
  "components": {
    "schemas": {
      "$ref": "./components/schemas-index.json"
    },
    "responses": {
      "$ref": "./components/responses.json"
    },
    "securitySchemes": {
      "$ref": "./components/security-schemes.json"
    }
  }
}
