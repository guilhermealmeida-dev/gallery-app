{
  "post": {
    "summary": "Redefinir senha",
    "description": "Redefine a senha de um usuário utilizando um token de recuperação válido.",
    "tags": ["Auth"],
    "security": [],
    "requestBody": {
      "required": true,
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "token": {
                "type": "string",
                "description": "Token de recuperação de senha",
                "example": "c2f5e1a9-9c3b-4d2a-a7c1-123456abcdef"
              },
              "newPassword": {
                "type": "string",
                "format": "password",
                "description": "Nova senha do usuário",
                "example": "NovaSenha@123"
              }
            },
            "required": ["token", "newPassword"]
          }
        }
      }
    },
    "responses": {
      "200": {
        "description": "OK",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "type": "string",
                  "example": "Senha atualizada com sucesso!"
                }
              },
              "required": ["message"]
            }
          }
        }
      },

      "400": {
        "$ref": "../../components/responses.json#/ValidatorRequest-BadRequest"
      },

      "401": {
        "$ref": "../../components/responses.json#/InvalidToken"
      },

      "500": {
        "$ref": "../../components/responses.json#/InternalServerError"
      }
    }
  }
}
