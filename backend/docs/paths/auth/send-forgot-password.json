{
  "post": {
    "summary": "Enviar e-mail de recuperação de senha",
    "description": "Solicita o envio de um e-mail de recuperação de senha para o endereço informado. Por motivos de segurança, a resposta é sempre a mesma, independentemente da existência da conta.",
    "tags": ["Auth"],
    "requestBody": {
      "required": true,
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "email": {
                "type": "string",
                "format": "email",
                "example": "usuario@email.com"
              }
            },
            "required": ["email"]
          }
        }
      }
    },
    "responses": {
      "200": {
        "description": "OK",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "type": "string",
                  "example": "Se houver uma conta será enviado um email de recuperação"
                }
              },
              "required": ["message"]
            }
          }
        }
      },

      "400": {
        "$ref": "../../components/responses.json#/ValidatorRequest-BadRequest"
      },

      "500": {
        "$ref": "../../components/responses.json#/InternalServerError"
      }
    }
  }
}