{
  "get": {
    "summary": "Validar token de recuperação de senha",
    "description": "Valida um token de recuperação de senha antes de permitir que o usuário defina uma nova senha.",
    "tags": ["Auth"],
    "security": [],
    "parameters": [
      {
        "name": "token",
        "in": "query",
        "required": true,
        "description": "Token de recuperação de senha",
        "schema": {
          "type": "string",
          "example": "c2f5e1a9-9c3b-4d2a-a7c1-123456abcdef"
        }
      }
    ],
    "responses": {
      "200": {
        "description": "OK",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "type": "string",
                  "example": "Token válido"
                }
              },
              "required": ["message"]
            }
          }
        }
      },

      "401": {
        "$ref": "../../components/responses.json#/InvalidToken"
      },

      "500": {
        "$ref": "../../components/responses.json#/InternalServerError"
      }
    }
  }
}
