{
  "UserOutputSchema": {
    "type": "object",
    "title": "UserOutputSchema",
    "description": "Representa o usuário retornado pela API.",
    "properties": {
      "id": {
        "type": "string",
        "format": "uuid",
        "description": "Identificador único do usuário.",
        "example": "c1a2b3d4-e5f6-7890-abcd-1234567890ef"
      },
      "name": {
        "type": "string",
        "description": "Nome completo do usuário.",
        "example": "João Silva"
      },
      "email": {
        "type": "string",
        "format": "email",
        "description": "E-mail do usuário.",
        "example": "joao.silva@email.com"
      },
      "avatar": {
        "type": "string",
        "format": "uri",
        "nullable": true,
        "description": "URL da foto de perfil do usuário.",
        "example": "https://api.example.com/storage/avatars/c1a2b3d4-e5f6-7890-abcd-1234567890ef.jpg"
      }
    },
    "required": [
      "id",
      "name",
      "email"
    ]
  }
}