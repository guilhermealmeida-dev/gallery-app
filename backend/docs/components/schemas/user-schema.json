{
  "UserUpdateSchema": {
    "type": "object",
    "properties": {
      "name": {
        "type": "string",
        "example": "Usern name"
      },
      "password": {
        "type": "string",
        "format": "text",
        "example": "123456"
      }
    }
  },
  
  "UserOutputSchema": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string",
        "format": "uuid"
      },
      "name": {
        "type": "string"
      },
      "email": {
        "type": "string",
        "format": "email"
      },
      "albuns": {
        "type": "array",
        "items": {
          "$ref": "#/AlbumOutputSchema"
        }
      }
    }
  },
  "AlbumOutputSchema": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string",
        "format": "uuid"
      },
      "name": {
        "type": "string"
      },
      "userid": {
        "type": "string",
        "format": "uuid"
      }
    }
  }
}