{
  "InternalServerError": {
    "description": "Error: Internal Server Error",
    "content": {
      "application/json": {
        "schema": {
          "allOf": [
            { "$ref": "./schemas/generic-schema.json#/ErrorModel" },
            {
              "properties": {
                "error": {
                  "properties": {
                    "message": {
                      "example": "Erro interno no servidor."
                    },
                    "code": {
                      "example": "internal_error"
                    },
                    "details": {
                      "nullable": true,
                      "example": null
                    }
                  }
                }
              }
            }
          ]
        }
      }
    }
  },

  "ValidatorRequest-BadRequest": {
    "description": "Bad Request",
    "content": {
      "application/json": {
        "schema": {
          "$ref": "./schemas/generic-schema.json#/ErrorModel"
        },
        "examples": {
          "ValidatorBodyExample": {
            "summary": "Erro de validação do body",
            "value": {
              "error": {
                "message": "Informe todos os campos corretamente.",
                "code": "schema_validator",
                "details": {
                  "password": [
                    "Tipo inválido: esperado string, recebido undefined"
                  ]
                }
              }
            }
          },
          "InvalidJsonExample": {
            "summary": "JSON inválido",
            "value": {
              "error": {
                "message": "JSON inválido",
                "code": "invalid_json",
                "details": "Expected double-quoted property name in JSON at position 35 (line 4 column 1)"
              }
            }
          }
        }
      }
    }
  },

  "ConflictError": {
