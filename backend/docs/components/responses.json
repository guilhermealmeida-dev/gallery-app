                      "example": "O email informado já está cadastrado."
                    },
                    "code": {
                      "example": "email_already_exists"
                    },
                    "details": {
                      "nullable": true,
                      "example": null
                    }
                  }
                }
              }
            }
          ]
        }
      }
    }
  },

