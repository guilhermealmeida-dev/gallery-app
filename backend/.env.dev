#SERVERS

#api
# host onde a aplicação escuta (Docker: 0.0.0.0)
API_HOST=0.0.0.0

# porta onde a API será executada
API_PORT=4000

# endereço público usado em links (ex: email de confirmação)
API_URL=http://localhost:4000


#front
# endereço público do frontend
FRONT_URL=http://localhost:3000


#DATABASE

# URL de conexão com o banco de dados para aplicação
# exemplo: postgresql://usuario:senha@host:porta/database
DATABASE_URL=postgresql://usuario:senha@host:5432/database

# URL de conexão direta com o banco para migrations
# exemplo: postgresql://usuario:senha@host:porta/database
DIRECT_URL=postgresql://usuario:senha@host:5432/database


#STORAGE

# endpoint do serviço de armazenamento (S3, Supabase Storage, LocalStack etc.)
# exemplo: http://localhost:4566
STORAGE_ENDPOINT=

# região do storage
# exemplo: us-east-1
STORAGE_REGION=

# chave de acesso do storage
STORAGE_ACCESS_KEY_ID=

# chave secreta do storage
STORAGE_SECRET_KEY=

# token temporário de sessão (opcional)
STORAGE_SESSION_TOKEN=


#buckets

# bucket utilizado para imagens de perfil
BUCKET_PROFILES=

# bucket utilizado para armazenamento de fotos
BUCKET_PHOTOS=


#MAIL

# servidor SMTP
# exemplo: smtp.gmail.com
MAIL_HOST=

# porta SMTP
# exemplo: 587 (TLS) ou 465 (SSL)
MAIL_PORT=

# habilita conexão segura SSL
# exemplo: true ou false
MAIL_SECURE=

# usuário do SMTP
MAIL_USER=

# senha ou senha de aplicação do SMTP
MAIL_PASS=